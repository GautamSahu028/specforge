# =============================================================
# SpecForge — Environment Variables Template
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Set GROQ_API_KEY and strong passwords
# 3. Run:             docker-compose up --build
# =============================================================

# =============================================================
# Database (MySQL 8)
# DB_HOST must be "db" when using Docker Compose (service name).
# Change to "localhost" only when running outside Docker.
# =============================================================
DB_HOST=db
DB_PORT=3306
DB_USER=specforge_user
DB_PASSWORD=change_me_strong_password
DB_NAME=specforge

# Root password used by the MySQL container itself
MYSQL_ROOT_PASSWORD=change_me_root_password

# =============================================================
# Backend Application
# =============================================================
APP_ENV=development
APP_PORT=3000

# Browser-visible origin of the frontend (used for CORS)
CORS_ORIGIN=http://localhost:5173

# Max API requests per IP per minute
RATE_LIMIT_PER_MINUTE=100

# =============================================================
# AI Service (Groq)
# Get a free key at: https://console.groq.com
# =============================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.1
LOG_LEVEL=INFO
